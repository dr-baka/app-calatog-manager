LOGIN_REDIRECT_URL=dashboard
LOGOUT_REDIRECT_URL=login
ADMIN_PATH=admin/

# Production security switches.
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
